#!/usr/bin/env zsh
#
# Set the iTerm2 tab color to a named color, using `pastel` for color data.
#

usage() {
  print "Set the iTerm2 tab color to a named color."
  print
  print "Usage:"
  print "  tab-color <color-name>       set tab color (any name pastel knows)"
  print "  tab-color -r, --random       set tab to a random named color"
  print "  tab-color -l, --list         print available color names (hue-sorted)"
  print "  tab-color -h, --help         show this help"
}

name="$1"

if [[ -z "$name" ]]; then
  usage >&2
  exit 1
fi

case "$name" in
  -h|--help)   usage; exit 0 ;;
  -l|--list)   pastel list; exit 0 ;;
  -r|--random) rgb=$(pastel random -n 1 | pastel format rgb) ;;
  *)
    rgb=$(pastel format rgb "$name" 2>/dev/null) || {
      print "Unknown color: $name" >&2
      print "Run 'tab-color --list' for available colors." >&2
      exit 1
    }
    ;;
esac

# rgb is "rgb(R, G, B)" — strip non-numeric to get "R G B"
read -r r g b <<<"${rgb//[^0-9]/ }"
printf '\033]6;1;bg;red;brightness;%d\a' "$r"
printf '\033]6;1;bg;green;brightness;%d\a' "$g"
printf '\033]6;1;bg;blue;brightness;%d\a' "$b"
