#!/usr/bin/env zsh
#
# Apply the manifest.toml configuration for the current host.
#
# Task behavior matrix:
#   check passes       → skip silently
#   run only           → auto-execute
#   run + prompt       → print prompt, confirm, then run
#   prompt only        → print prompt (manual action needed)
#

local DOTKYL="${0:A:h:h}"  # ${0:A:h:h} = absolute path to this script's grandparent dir
local MANIFEST="$DOTKYL/manifest.toml"
local DOTKYL_HOST=$("$DOTKYL/bin/get-host")

if [[ ! -f "$MANIFEST" ]]; then
    print "error: $MANIFEST not found" >&2
    exit 1
fi

local failed=0
local summary=""

# Single yq call: filter tasks for this host, drop the hosts field
local tasks=$(yq -p toml -oy \
    "[.task[] | select(.hosts == null or .hosts[] == \"$DOTKYL_HOST\") | del(.hosts)]" \
    "$MANIFEST")

# --- Task handlers ---

check_ok() {
    local name=$1 cmd=$2
    [[ -n "$cmd" ]] && eval "$cmd" &>/dev/null && summary+="  ☑ ❬$name❭\n"
}

note() {
    local name=$1 prompt=$2
    summary+="  → ❬$name❭ $prompt\n"
}

run_task() {
    local name=$1 cmd=$2
    if eval "$cmd" &>/dev/null; then
        summary+="  ✓ ❬$name❭\n"
    else
        summary+="  ✗ ❬$name❭\n"
        (( failed++ ))
    fi
}

confirm_run() {
    local name=$1 cmd=$2 prompt=$3
    print "  $prompt"
    printf "  Run now? [y/N] "
    read -q reply || true
    print  # newline after read -q
    if [[ "$reply" == "y" ]]; then
        run_task "$name" "$cmd"
    else
        summary+="  - ❬$name❭ (skipped)\n"
    fi
}

process_task() {
    local idx=$1
    # Load task fields as shell variables in one yq call:
    #   name, check, run, prompt — missing fields default to ""
    local name check run prompt
    eval "$(echo "$tasks" | yq -o shell \
        ".[$idx] | .check = (.check // \"\") | .run = (.run // \"\") | .prompt = (.prompt // \"\")")"

    if check_ok "$name" "$check"; then return; fi
    if [[ -n "$prompt" && -z "$run" ]]; then note "$name" "$prompt"; return; fi
    if [[ -n "$run" && -n "$prompt" ]]; then confirm_run "$name" "$run" "$prompt"; return; fi
    if [[ -n "$run" ]]; then run_task "$name" "$run"; return; fi
}

# --- Process tasks ---

local count=$(echo "$tasks" | yq '. | length')
for (( i = 0; i < count; i++ )); do
    process_task $i
done

print "\n==> Summary"
print "$summary"

if [[ "$failed" -gt 0 ]]; then
    exit 1
fi
