#!/usr/bin/env zsh
#
# Check that all expected symlinks are in place.
# Exits 0 if everything is correct, 1 if anything is missing or wrong.
#

local dotkyl="${0:A:h:h}"  # ${0:A:h:h} = absolute path to this script's grandparent dir
local ok=true

check_link() {
    local target=$1 link=$2
    if [[ ! -L "$link" || "$(readlink "$link")" != "$target" ]]; then
        print "missing or wrong: $link -> $target" >&2
        ok=false
    fi
}

# home/* -> ~/.<name>
for f in $dotkyl/home/*(N); do
    [[ "$(basename $f)" == "config" ]] && continue
    check_link "$f" ~/."$(basename $f)"
done

# private/home/* -> ~/.<name>
for f in $dotkyl/private/home/*(N); do
    [[ "$(basename $f)" == "config" ]] && continue
    check_link "$f" ~/."$(basename $f)"
done

# home/config/* -> ~/.config/<name>
for f in $dotkyl/home/config/*(N); do
    check_link "$f" ~/.config/"$(basename $f)"
done

# private/home/config/* -> ~/.config/<name>
for f in $dotkyl/private/home/config/*(N); do
    check_link "$f" ~/.config/"$(basename $f)"
done

# nvim -> ~/.config/nvim
check_link $dotkyl/nvim ~/.config/nvim

# iTerm2 dynamic profiles
local iterm_profiles=~/Library/Application\ Support/iTerm2/DynamicProfiles
for f in $dotkyl/iterm/*.json(N); do
    check_link "$f" "$iterm_profiles/$(basename $f)"
done

$ok
