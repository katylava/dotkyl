#!/usr/bin/env zsh
#
# Symlink dotfiles into ~/, ~/.config/, and iTerm2 DynamicProfiles.
# Handles both the main repo and the private repo.
# Idempotent — safe to run repeatedly. (-n prevents nesting into existing symlinked dirs)
#

local dotkyl="${0:A:h:h}"  # ${0:A:h:h} = absolute path to this script's grandparent dir

# Symlink home/* into ~/ as dotfiles (prefixed with .)
for f in $dotkyl/home/*(N); do
    [[ "$(basename $f)" == "config" ]] && continue
    ln -sfn "$f" ~/."$(basename $f)"
done

# Symlink private/home/* into ~/ as dotfiles
for f in $dotkyl/private/home/*(N); do
    [[ "$(basename $f)" == "config" ]] && continue
    ln -sfn "$f" ~/."$(basename $f)"
done

# Symlink home/config/* into ~/.config/
mkdir -p ~/.config
for f in $dotkyl/home/config/*(N); do
    ln -sfn "$f" ~/.config/"$(basename $f)"
done

# Symlink private/home/config/* into ~/.config/
for f in $dotkyl/private/home/config/*(N); do
    ln -sfn "$f" ~/.config/"$(basename $f)"
done

# Symlink nvim/ into ~/.config/
ln -sfn $dotkyl/nvim ~/.config/nvim

# Symlink iTerm2 dynamic profiles
local iterm_profiles=~/Library/Application\ Support/iTerm2/DynamicProfiles
mkdir -p "$iterm_profiles"
for f in $dotkyl/iterm/*.json(N); do
    ln -sfn "$f" "$iterm_profiles/$(basename $f)"
done

