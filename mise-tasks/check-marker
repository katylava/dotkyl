#!/usr/bin/env zsh
# Check if a tracked file changed in the last merge; if so, leave a marker
# and remind until the corresponding install task clears it.
#
# Usage: check-marker <file-pattern> <task-name>
# Example: check-marker Brewfile brew  →  marker .brew-outdated

set -euo pipefail

PATTERN=${1:?Usage: check-marker <file-pattern> <task-name>}
TASK=${2:?Usage: check-marker <file-pattern> <task-name>}
MARKER=".${TASK}-outdated"

if git diff HEAD@{1} --name-only 2>/dev/null | grep -q "$PATTERN"; then
  touch "$MARKER"
fi

if [[ -f "$MARKER" ]]; then
  echo "👉 $PATTERN changed — run: mise run $TASK"
else
  echo "⏭️ no $PATTERN changes"
fi
