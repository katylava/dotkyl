#!/usr/bin/env zsh
# Stow a one-time install task from root mise.toml into setup/mise.toml.
# Moves [tasks."install:<name>"] (renaming to [tasks.<name>] for setup's flat
# convention), deletes the [tasks."sync:<name>"] reminder, and commits (no push).
#
# Usage: mise run stow <name>      # short name, e.g. "peon-ping"

set -euo pipefail

name=${1:?Usage: mise run stow <name>}
repo_root=$(git -C "${0:A:h}" rev-parse --show-toplevel)
root_toml=$repo_root/mise.toml
setup_toml=$repo_root/setup/mise.toml
src_header="[tasks.\"install:$name\"]"

# Safety: task must already be in origin/main (pushed and pulled elsewhere)
git -C "$repo_root" fetch --quiet origin main
if ! git -C "$repo_root" show origin/main:mise.toml | grep -qF "$src_header"; then
  echo "❌ $src_header not in origin/main — push it first" >&2
  exit 1
fi

# Extract install: block: header through line before next [ header
task_block=$(awk -v header="$src_header" '
  $0 == header { in_block = 1; print; next }
  in_block && /^\[tasks\./ { exit }
  in_block { print }
' "$root_toml")

if [[ -z "$task_block" ]]; then
  echo "❌ $src_header not found in $root_toml" >&2
  exit 1
fi

# Pass block via tempfile (awk -v can't accept multiline values).
# Rewrite the install:-prefixed header to setup's flat naming convention.
block_file=$(mktemp)
echo "${task_block%$'\n'}" | gsed "1s|.*|[tasks.$name]|" > "$block_file"

# Insert block contents before [tasks.install] in setup_toml
tmp=$(mktemp)
awk -v bf="$block_file" '
  /^\[tasks\.install\]$/ {
    while ((getline line < bf) > 0) print line
    print ""
  }
  { print }
' "$setup_toml" > "$tmp"
mv "$tmp" "$setup_toml"
rm -f "$block_file"

# Add "<name>" to setup install depends array
sed -i '' -E \
  -e "s/^depends = \[\]$/depends = [\"$name\"]/" \
  -e "s/^(depends = \[[^]]+)\]$/\1, \"$name\"]/" \
  "$setup_toml"

# Delete install: and sync: blocks from root.
# (No need to touch the sync depends array — it uses sync:** wildcard.)
for header in "[tasks.\"install:$name\"]" "[tasks.\"sync:$name\"]"; do
  tmp=$(mktemp)
  awk -v h="$header" '
    $0 == h { in_block = 1; next }
    in_block && /^\[tasks\./ { in_block = 0 }
    in_block { next }
    !in_block { print }
  ' "$root_toml" > "$tmp"
  mv "$tmp" "$root_toml"
done

# Strip trailing blank lines left over from block deletions
tmp=$(mktemp)
awk '/./ {for(i=0;i<blanks;i++)print ""; blanks=0; print; next} {blanks++}' \
  "$root_toml" > "$tmp"
mv "$tmp" "$root_toml"

# Commit (no push — user reviews and pushes when ready)
git -C "$repo_root" add mise.toml setup/mise.toml
git -C "$repo_root" commit -m "setup: stow $name into setup/mise.toml"

echo "✅ stowed $name"
